      "text": "%spark.pyspark\nw = Window.partitionBy(\"city\").orderBy(F.desc(\"revenue_sum\"))\n\nmart_top2 = (mart\n             .withColumn(\"rn\", F.row_number().over(w))\n             .filter(F.col(\"rn\") <= 2)\n             .drop(\"rn\"))\n\nmart_top2.orderBy(\"city\", F.desc(\"revenue_sum\")).show(truncate=False)\n",
