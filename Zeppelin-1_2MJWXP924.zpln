    {
      "text": "%spark.pyspark\nmart = (base\n        .groupBy(\"city\",\"product_id\",\"product_name\")\n        .agg(\n            F.countDistinct(\"order_id\").alias(\"orders_cnt\"),\n            F.sum(\"qty\").alias(\"qty_sum\"),\n            F.sum(\"revenue\").alias(\"revenue_sum\"),\n        ))\nmart.orderBy(\"city\", F.desc(\"revenue_sum\")).show(truncate=False)\n",
